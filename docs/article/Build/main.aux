\newlabel{fig:ts}{{3}{14}{Five-day excerpt of the 6-hour GHI forecast from the best model (GraphSAGE-LSTM, fixed-graph, seed~42) at El~Paso in January 2024. Persistence (dashed) simply repeats the GHI observed 6~hours prior, while GraphSAGE-LSTM anticipates the diurnal rise and cloud events. Timestamps in local time (America/Bogotá, UTC$-5$)}{figure.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Aleatoric/epistemic uncertainty decomposition. $\sigma _\text  {ale}$, $\sigma _\text  {epi}$, $\sigma _\text  {total}$ in W/m² (Eq.~\ref {eq:decomposition}); $\hat  {\text  {cov}}_\text  {day}$: empirical daytime coverage of the combined interval $\bar  \mu \pm z_{1-\alpha /2}\sigma _\text  {total}$ on the test set. Backbone: GraphSAGE-LSTM for El~Paso; best-per-horizon deep-learning backbone for Uniandes (ResNet-LSTM at 1h, GraphSAGE-LSTM at 3h and 6h). \textit  {[SGLD sampling and variance-head training in progress; values to be populated as runs complete.]}}}{14}{table.caption.15}\protected@file@percent }
\newlabel{tab:decomposition}{{7}{14}{Aleatoric/epistemic uncertainty decomposition. $\sigma _\text {ale}$, $\sigma _\text {epi}$, $\sigma _\text {total}$ in W/m² (Eq.~\ref {eq:decomposition}); $\hat {\text {cov}}_\text {day}$: empirical daytime coverage of the combined interval $\bar \mu \pm z_{1-\alpha /2}\sigma _\text {total}$ on the test set. Backbone: GraphSAGE-LSTM for El~Paso; best-per-horizon deep-learning backbone for Uniandes (ResNet-LSTM at 1h, GraphSAGE-LSTM at 3h and 6h). \textit {[SGLD sampling and variance-head training in progress; values to be populated as runs complete.]}}{table.caption.15}{}}
