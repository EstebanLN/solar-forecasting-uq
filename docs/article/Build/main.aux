\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Daytime skill score ($\text  {Skill}_\text  {day}$) for ResNet-LSTM, GraphSAGE-LSTM (both Optuna-tuned, fixed-graph variant, four seeds), persistence, and SARIMA, at both sites across three forecast horizons. Bars show mean over four seeds; error bars indicate $\pm 1$ standard deviation. Persistence has no seed variability. The hatched SARIMA bars are evaluated on a coarser, on-the-hour subset of the test set with their own recomputed persistence reference (Section~\ref {ssec:sarima}) and are \textbf  {not directly comparable} to the other bars; FlatMLP is omitted pending completion of its Optuna sweep (Section~\ref {sec:discussion}, Limitations). GraphSAGE-LSTM achieves the highest skill among the deep-learning models at the 6-hour horizon at both sites (0.636 at El~Paso; 0.417 at Uniandes).}}{12}{figure.caption.9}\protected@file@percent }
\newlabel{fig:skill}{{1}{12}{Daytime skill score ($\skillday $) for ResNet-LSTM, GraphSAGE-LSTM (both Optuna-tuned, fixed-graph variant, four seeds), persistence, and SARIMA, at both sites across three forecast horizons. Bars show mean over four seeds; error bars indicate $\pm 1$ standard deviation. Persistence has no seed variability. The hatched SARIMA bars are evaluated on a coarser, on-the-hour subset of the test set with their own recomputed persistence reference (Section~\ref {ssec:sarima}) and are \textbf {not directly comparable} to the other bars; FlatMLP is omitted pending completion of its Optuna sweep (Section~\ref {sec:discussion}, Limitations). GraphSAGE-LSTM achieves the highest skill among the deep-learning models at the 6-hour horizon at both sites (0.636 at El~Paso; 0.417 at Uniandes)}{figure.caption.9}{}}
